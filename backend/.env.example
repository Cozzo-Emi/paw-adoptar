# ============================================
# PAW — Variables de Entorno (template)
# Copiar a .env y completar con valores reales
# ============================================

# --- Base de datos ---
POSTGRES_USER=paw_user
POSTGRES_PASSWORD=
POSTGRES_DB=paw_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paw_user:PASSWORD@HOST:5432/paw_db

# --- JWT / Auth ---
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase (notificaciones push) ---
# Ruta al archivo JSON de credenciales del Admin SDK
# Dejar vacío para usar modo mock (no envía push reales)
FIREBASE_CREDENTIALS_PATH=

# --- App ---
APP_NAME=PAW
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["*"]
