# ============================================
# PAW — Variables de Entorno (template)
# Copiar a .env y completar con valores reales
# ============================================

# --- Base de datos ---
POSTGRES_USER=paw_user
POSTGRES_PASSWORD=paw_secret_dev
POSTGRES_DB=paw_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paw_user:paw_secret_dev@db:5432/paw_db

# --- JWT / Auth ---
SECRET_KEY=CAMBIAR_POR_UN_SECRET_SEGURO_DE_AL_MENOS_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase (notificaciones push) ---
FIREBASE_CREDENTIALS_PATH=

# --- App ---
APP_NAME=PAW
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
